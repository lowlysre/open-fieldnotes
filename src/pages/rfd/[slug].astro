---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import config from '../../../fieldnotes.config.json';
import { labelTextColor } from '../../lib/color';
import { Badge, Link } from 'accessible-astro-components';

export async function getStaticPaths() {
  const rfds = await getCollection('rfds');
  return rfds.map((rfd) => ({
    params: { slug: rfd.data.number },
    props: { rfd },
  }));
}

const { rfd } = Astro.props;
const { Content } = await render(rfd);

const stateConfig = config.states[rfd.data.state] ?? config.states.discussion;
const stateColor = stateConfig?.color ?? '#6b7280';
const stateTextColor = labelTextColor(stateColor.replace(/^#/, ''));
const authorLogin = rfd.data.author.trim();
const authorProfileUrl = `https://github.com/${authorLogin}`;

const createdDate = new Date(rfd.data.createdAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updatedDate = new Date(rfd.data.updatedAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const createdTimestamp = new Date(rfd.data.createdAt).toLocaleString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
  hour: '2-digit', minute: '2-digit', second: '2-digit', timeZoneName: 'short',
});
const updatedTimestamp = new Date(rfd.data.updatedAt).toLocaleString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
  hour: '2-digit', minute: '2-digit', second: '2-digit', timeZoneName: 'short',
});

const baseUrl = config.base.replace(/\/$/, '');
const wordCount = (rfd.body ?? '').split(/\s+/).filter(Boolean).length;
const minutesRead = Math.max(1, Math.ceil(wordCount / 200));
---

<Layout title={`RFD ${rfd.data.number}: ${rfd.data.title}`}>
  <style>
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.875rem;
      color: var(--color-text-muted);
      margin-bottom: 1.75rem;
    }

    .back-link:hover {
      color: var(--color-link);
      text-decoration: none;
    }

    /* ── RFD header ────────────────────────────────────────────────── */
    .rfd-header {
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 1.5rem;
      margin-bottom: 2rem;
    }

    .rfd-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--color-text-muted);
      margin: 0 0 0.4rem 0;
    }

    .rfd-header h1 {
      font-size: 1.75rem;
      line-height: 1.25;
      margin: 0 0 1rem 0;
    }

    .rfd-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.875rem;
      color: var(--color-text-muted);
      align-items: center;
    }

    .rfd-meta a {
      color: var(--color-text-muted);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .rfd-meta a:hover {
      color: var(--color-link);
    }

    .label-list {
      display: flex;
      gap: 0.3rem;
      flex-wrap: wrap;
    }

    .label-chip {
      display: inline-block;
      padding: 0.15em 0.5em;
      border-radius: var(--radius);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      font-size: 0.75rem;
      text-decoration: none;
    }

    .rfd-meta .label-chip,
    .rfd-meta .label-chip:hover,
    .rfd-meta .label-chip:focus-visible,
    .rfd-meta .label-chip:visited {
      text-decoration: none;
    }

    /* ── RFD body ──────────────────────────────────────────────────── */
    .rfd-body {
      width: 100%;
      max-width: none;
      line-height: 1.75;
    }

    .rfd-body :global(h1),
    .rfd-body :global(h2),
    .rfd-body :global(h3),
    .rfd-body :global(h4) {
      margin-top: 2em;
      margin-bottom: 0.5em;
      line-height: 1.3;
    }

    .rfd-body :global(h2) {
      font-size: 1.35rem;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 0.25em;
    }

    .rfd-body :global(p) {
      margin: 0 0 1em 0;
    }

    .rfd-body :global(ul),
    .rfd-body :global(ol) {
      padding-left: 1.5em;
      margin: 0 0 1em 0;
    }

    .rfd-body :global(li) {
      margin-bottom: 0.3em;
    }

    .rfd-body :global(blockquote) {
      border-left: 3px solid var(--color-border);
      margin: 1em 0;
      padding: 0.25em 1em;
      color: var(--color-text-muted);
    }

    /* Comments are rendered as blockquotes after this heading. */
    .rfd-body :global(#discussion-comments) {
      margin-top: 2.5rem;
    }

    .rfd-body :global(#discussion-comments) ~ :global(blockquote) {
      margin-left: 1.25rem;
      border-left-width: 2px;
      background: var(--color-surface);
      color: var(--color-text-muted);
      padding: 0.6em 1em;
    }

    .rfd-body :global(#discussion-comments) ~ :global(blockquote p) {
      color: var(--color-text-muted);
    }

    .rfd-body :global(#discussion-comments) ~ :global(blockquote p:first-child) {
      margin-bottom: 0.65rem;
    }

    .rfd-body :global(#discussion-comments) ~ :global(blockquote p:first-child strong) {
      font-weight: 600;
    }

    .rfd-body :global(#discussion-comments) ~ :global(blockquote a) {
      color: inherit;
      text-decoration: underline;
      text-decoration-color: var(--color-border);
      text-underline-offset: 2px;
    }

    .rfd-body :global(#discussion-comments) ~ :global(blockquote a:hover) {
      color: var(--color-link);
      text-decoration-color: var(--color-link);
    }

    .rfd-body :global(#discussion-comments) ~ :global(blockquote a.comment-author-link) {
      font-weight: 600;
      text-decoration: none;
    }

    .rfd-body :global(#discussion-comments) ~ :global(blockquote a.comment-author-link:hover) {
      text-decoration: underline;
    }

    .rfd-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9em;
      margin-bottom: 1em;
    }

    .rfd-body :global(th),
    .rfd-body :global(td) {
      padding: 0.5em 0.75em;
      border: 1px solid var(--color-border);
      text-align: left;
    }

    .rfd-body :global(th) {
      background: var(--color-surface);
    }

    .rfd-body :global(img) {
      max-width: 100%;
      border-radius: var(--radius);
    }

    .rfd-body :global(hr) {
      border: none;
      border-top: 1px solid var(--color-border);
      margin: 2em 0;
    }
  </style>

  <Link href={`${baseUrl}/`} class="back-link">← Back to index</Link>

  <div class="rfd-header">
    <p class="rfd-eyebrow">RFD {rfd.data.number}</p>
    <h1>{rfd.data.title}</h1>
    <div class="rfd-meta">
      <Badge
        isPill
        size="sm"
        style={`background-color: ${stateColor}; border-color: transparent; color: ${stateTextColor}`}
      >
        {stateConfig?.label ?? rfd.data.state}
      </Badge>
      <span>
        by <Link href={authorProfileUrl} isExternal hideIcon>@{authorLogin}</Link>
      </span>
      <span>
        Created <time datetime={rfd.data.createdAt} title={createdTimestamp}>{createdDate}</time>
      </span>
      <span>
        Updated <time datetime={rfd.data.updatedAt} title={updatedTimestamp}>{updatedDate}</time>
      </span>
      <span>{minutesRead} min read</span>
      {rfd.data.labels.length > 0 && (
        <div class="label-list">
          {rfd.data.labels.map((label, i) => (
            <Link
              href={`https://github.com/${config.org}/${config.repo}/discussions?label%3A${encodeURIComponent(label)}`}
              isExternal
              hideIcon
              class="label-chip"
              style={rfd.data.labelColors[i] ? `background-color: #${rfd.data.labelColors[i]}; color: ${labelTextColor(rfd.data.labelColors[i])}; border-color: transparent` : ''}
            >{label}</Link>
          ))}
        </div>
      )}
      <Link
        href={rfd.data.discussionUrl}
        isExternal
      >
        View Discussion ↗
      </Link>
    </div>
  </div>

  <div class="rfd-body">
    <Content />
  </div>
</Layout>
