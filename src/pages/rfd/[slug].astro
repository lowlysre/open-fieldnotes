---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import config from '../../../fieldnotes.config.mjs';

export async function getStaticPaths() {
  const rfds = await getCollection('rfds');
  return rfds.map((rfd) => ({
    params: { slug: rfd.data.number },
    props: { rfd },
  }));
}

const { rfd } = Astro.props;
const { Content } = await render(rfd);

const stateConfig = config.states[rfd.data.state] ?? config.states.discussion;

const createdDate = new Date(rfd.data.createdAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updatedDate = new Date(rfd.data.updatedAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const baseUrl = config.base.replace(/\/$/, '');
---

<Layout title={`RFD ${rfd.data.number}: ${rfd.data.title}`}>
  <style>
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.875rem;
      color: var(--color-text-muted);
      margin-bottom: 1.75rem;
    }

    .back-link:hover {
      color: var(--color-link);
      text-decoration: none;
    }

    /* ── RFD header ────────────────────────────────────────────────── */
    .rfd-header {
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 1.5rem;
      margin-bottom: 2rem;
    }

    .rfd-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--color-text-muted);
      margin: 0 0 0.4rem 0;
    }

    .rfd-header h1 {
      font-size: 1.75rem;
      line-height: 1.25;
      margin: 0 0 1rem 0;
    }

    .rfd-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.875rem;
      color: var(--color-text-muted);
      align-items: center;
    }

    .state-badge {
      display: inline-block;
      padding: 0.2em 0.65em;
      border-radius: 9999px;
      font-size: 0.8rem;
      font-weight: 600;
      color: #fff;
    }

    .rfd-meta a {
      color: var(--color-text-muted);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .rfd-meta a:hover {
      color: var(--color-link);
    }

    .label-list {
      display: flex;
      gap: 0.3rem;
      flex-wrap: wrap;
    }

    .label-chip {
      display: inline-block;
      padding: 0.15em 0.5em;
      border-radius: var(--radius);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      font-size: 0.75rem;
    }

    /* ── RFD body ──────────────────────────────────────────────────── */
    .rfd-body {
      max-width: 70ch;
      line-height: 1.75;
    }

    .rfd-body :global(h1),
    .rfd-body :global(h2),
    .rfd-body :global(h3),
    .rfd-body :global(h4) {
      margin-top: 2em;
      margin-bottom: 0.5em;
      line-height: 1.3;
    }

    .rfd-body :global(h2) {
      font-size: 1.35rem;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 0.25em;
    }

    .rfd-body :global(p) {
      margin: 0 0 1em 0;
    }

    .rfd-body :global(ul),
    .rfd-body :global(ol) {
      padding-left: 1.5em;
      margin: 0 0 1em 0;
    }

    .rfd-body :global(li) {
      margin-bottom: 0.3em;
    }

    .rfd-body :global(blockquote) {
      border-left: 3px solid var(--color-border);
      margin: 1em 0;
      padding: 0.25em 1em;
      color: var(--color-text-muted);
    }

    .rfd-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9em;
      margin-bottom: 1em;
    }

    .rfd-body :global(th),
    .rfd-body :global(td) {
      padding: 0.5em 0.75em;
      border: 1px solid var(--color-border);
      text-align: left;
    }

    .rfd-body :global(th) {
      background: var(--color-surface);
    }

    .rfd-body :global(img) {
      max-width: 100%;
      border-radius: var(--radius);
    }

    .rfd-body :global(hr) {
      border: none;
      border-top: 1px solid var(--color-border);
      margin: 2em 0;
    }
  </style>

  <a href={`${baseUrl}/`} class="back-link">← Back to index</a>

  <div class="rfd-header">
    <p class="rfd-eyebrow">RFD {rfd.data.number}</p>
    <h1>{rfd.data.title}</h1>
    <div class="rfd-meta">
      <span
        class="state-badge"
        style={`background-color: ${stateConfig?.color ?? '#6b7280'}`}
      >
        {stateConfig?.label ?? rfd.data.state}
      </span>
      <span>by <strong>{rfd.data.author}</strong></span>
      <span>Created {createdDate}</span>
      <span>Updated {updatedDate}</span>
      {rfd.data.labels.length > 0 && (
        <div class="label-list">
          {rfd.data.labels.map((label) => (
            <span class="label-chip">{label}</span>
          ))}
        </div>
      )}
      <a
        href={rfd.data.discussionUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        View Discussion ↗
      </a>
    </div>
  </div>

  <div class="rfd-body">
    <Content />
  </div>
</Layout>
