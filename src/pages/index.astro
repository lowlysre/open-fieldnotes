---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import config from '../../fieldnotes.config.json';
import '../styles/index.css';
import { labelTextColor } from '../lib/color';
import { Badge, Button, Input, Link } from 'accessible-astro-components';

const allRfds = await getCollection('rfds');
const rfds = allRfds.sort((a, b) => b.data.number.localeCompare(a.data.number));

const baseUrl = config.base.replace(/\/$/, '');
const searchIndexUrl = `${baseUrl}/search-index.json`;
const indexHeading = config.indexHeading ?? 'RFD Index';
---

<Layout title="Index" description={config.description}>
  <div class="index-page" data-search-index-url={searchIndexUrl}>
    <div class="page-header">
      <h1>{indexHeading}</h1>
      <p>{config.description}</p>
    </div>

    <div class="filters">
    <Input
      type="text"
      class="filter-search"
      id="search-input"
      name="search-rfds"
      label="Search RFDs"
      placeholder="Search title, number, labels, author, body, or comments ..."
      data-validation=""
    />
    <div class="filter-row">
      <div class="state-filters" id="state-filters">
        {Object.entries(config.states).map(([key, val]) => (
          <Button
            htmlType="button"
            variant="outlined"
            size="sm"
            class="state-btn"
            data-state={key}
            aria-pressed="false"
            style={`--state-color: ${val.color}`}
          >
            {val.label}
          </Button>
        ))}
      </div>
      <div class="sort-control">
        <label for="sort-select">Sort by</label>
        <select id="sort-select" name="sort">
          <option value="updated-desc">Last updated (newest)</option>
          <option value="updated-asc">Last updated (oldest)</option>
          <option value="number-desc" selected>Newest number</option>
          <option value="number-asc">Oldest number</option>
          <option value="title-asc">Title (A-Z)</option>
          <option value="title-desc">Title (Z-A)</option>
        </select>
      </div>
    </div>
    </div>

    <ul class="rfd-results" id="rfd-results-list" aria-label="RFD results">
        {rfds.map((rfd) => {
          const stateConfig = config.states[rfd.data.state] ?? config.states.discussion;
          const stateColor = stateConfig?.color ?? '#6b7280';
          const stateTextColor = labelTextColor(stateColor.replace(/^#/, ''));
          const updatedDate = new Date(rfd.data.updatedAt).toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric'
          });
          return (
            <li
              class="rfd-row"
              data-rfd-row
              data-state={rfd.data.state}
              data-title={rfd.data.title.toLowerCase()}
              data-number={rfd.data.number.toLowerCase()}
              data-updated={rfd.data.updatedAt}
              data-labels={rfd.data.labels.join(' ').toLowerCase()}
              data-author={rfd.data.author.toLowerCase()}
            >
              <div class="rfd-cell rfd-number">
                <span class="rfd-cell-label">Number</span>
                <Link href={`${baseUrl}/rfd/${rfd.data.number}`} class="rfd-title-link">
                  {rfd.data.number}
                </Link>
              </div>

              <div class="rfd-cell">
                <span class="rfd-cell-label">Title</span>
                <Link href={`${baseUrl}/rfd/${rfd.data.number}`} class="rfd-title-link">
                  {rfd.data.title}
                </Link>
              </div>

              <div class="rfd-cell">
                <span class="rfd-cell-label">State</span>
                <Badge
                  isPill
                  size="sm"
                  style={`background-color: ${stateColor}; border-color: transparent; color: ${stateTextColor}`}
                >
                  {stateConfig?.label ?? rfd.data.state}
                </Badge>
              </div>

              <div class="rfd-cell rfd-updated">
                <span class="rfd-cell-label">Updated</span>
                <span>{updatedDate}</span>
              </div>

              <div class="rfd-cell">
                <span class="rfd-cell-label">Labels</span>
                <div class="label-list">
                  {rfd.data.labels.map((label, i) => (
                    <Link
                      href={`https://github.com/${config.org}/${config.repo}/discussions?label%3A${encodeURIComponent(label)}`}
                      isExternal
                      hideIcon
                      class="label-chip"
                      style={rfd.data.labelColors[i] ? `background-color: #${rfd.data.labelColors[i]}; color: ${labelTextColor(rfd.data.labelColors[i])}; border-color: transparent` : ''}
                    >{label}</Link>
                  ))}
                </div>
              </div>
            </li>
          );
        })}
    </ul>
    <p class="no-results" id="no-results">No RFDs match your filters 🙊</p>
  </div>
</Layout>

<script>
  import '../scripts/index-page.ts';
</script>
