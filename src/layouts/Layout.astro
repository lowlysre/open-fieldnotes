---
// Layout.astro — base layout for all pages
import config from '../../fieldnotes.config.mjs';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ${config.title}` : config.title;
const pageDescription = description ?? config.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <style>
      :root {
        --color-bg: #ffffff;
        --color-surface: #f8f9fa;
        --color-border: #e5e7eb;
        --color-text: #111827;
        --color-text-muted: #6b7280;
        --color-link: #1d4ed8;
        --color-link-hover: #1e40af;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        --font-mono: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo,
          Courier, monospace;
        --max-width: 1100px;
        --radius: 4px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: var(--color-link);
        text-decoration: none;
      }

      a:hover {
        color: var(--color-link-hover);
        text-decoration: underline;
      }

      /* ── Site header ───────────────────────────────────────────────── */
      .site-header {
        border-bottom: 1px solid var(--color-border);
        background: var(--color-surface);
        padding: 0 1.5rem;
      }

      .site-header-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        align-items: center;
        height: 56px;
        gap: 1rem;
      }

      .site-header a {
        font-weight: 600;
        font-size: 1rem;
        color: var(--color-text);
        text-decoration: none;
      }

      .site-header a:hover {
        color: var(--color-link);
        text-decoration: none;
      }

      /* ── Main content ──────────────────────────────────────────────── */
      .site-main {
        flex: 1;
        padding: 2rem 1.5rem;
        max-width: var(--max-width);
        margin: 0 auto;
        width: 100%;
      }

      /* ── Footer ────────────────────────────────────────────────────── */
      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 1rem 1.5rem;
        text-align: center;
        font-size: 0.8125rem;
        color: var(--color-text-muted);
      }

      /* ── Code ──────────────────────────────────────────────────────── */
      pre,
      code {
        font-family: var(--font-mono);
        font-size: 0.875em;
      }

      pre {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 1rem;
        overflow-x: auto;
      }

      code:not(pre code) {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 0.1em 0.35em;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href={config.base}>{config.title}</a>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>Powered by <a href="https://github.com/lowlydba/open-fieldnotes" target="_blank" rel="noopener">OpenFieldnotes</a></p>
    </footer>
  </body>
</html>
